{
  "name": "pupy-backend",
  "version": "1.0.0",
  "description": "PUPY爪住 - 宠物社交平台 & AI克隆 后端API服务",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && echo 'Build complete'" ,
    "start": "node dist/src/server.js",
    "migrate": "node --loader tsx src/database/migrate.ts",
    "seed": "node --loader tsx src/database/seed.ts",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "@supabase/supabase-js": "^2.38.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "express-validator": "^7.0.0",
    "uuid": "^9.0.0",
    "axios": "^1.5.0",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/uuid": "^9.0.2",
    "@types/cors": "^2.8.17",
    "@vercel/node": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
